{
    "name": "tschueller/phpmysqlgrid",
    "type": "library",
    "license": "MIT",
    "description": "A flexible MySQL data grid for PHP with support for filtering, sorting, pagination and CRUD operations.",
    "keywords": ["php", "mysql", "grid", "datagrid", "table", "pagination", "filtering", "sorting", "crud", "pdo", "sql", "database", "mariadb", "sqlite"],
    "authors": [
        {
            "name": "Klaus Reimer",
            "email": "k@ailis.de"
        },
        {
            "name": "Thorsten Schüller",
            "email": "thorsten@schueller.me"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*"
    },
    "require-dev": {
        "ext-pdo_sqlite": "*",
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^1.0",
        "phpunit/phpunit": "^11.5"
    },
    "suggest": {
        "ext-pdo_mysql": "Required for the default MySQL/MariaDB connection mode.",
        "ext-pdo_sqlite": "Required for the demo and SQLite-backed tests."
    },
    "bin": [
        "bin/phpmysqlgrid-assets"
    ],
    "autoload": {
        "psr-4": {
            "PhpMySQLGrid\\": "src/"
        }
    },
    "config": {
        "platform": {
            "php": "8.2.0"
        }
    },
    "scripts": {
        "lint:syntax": "php bin/lint-syntax",
        "lint:style": "php-cs-fixer fix --dry-run --diff",
        "fix:style": "php-cs-fixer fix",
        "lint:static": "phpstan analyse --memory-limit=512M",
        "test": "phpunit",
        "assets:publish": "php bin/phpmysqlgrid-assets",
        "demo:start": [
            "Composer\\Config::disableProcessTimeout",
            "php -S 127.0.0.1:8000 -t . demo/router.php"
        ],
        "lint": [
            "@lint:syntax",
            "@lint:style",
            "@lint:static"
        ]
    }
}
